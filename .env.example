# Stock Analyzer 配置模板
# 复制此文件为 .env 并填写实际值

# ========================================
# 数据源配置
# ========================================

# Tushare API Token（必需）
# 获取地址：https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here

# ========================================
# 分析配置
# ========================================

# 日K线数据抓取天数（默认：120）
ANALYSIS_DAYS=120

# 最少数据天数要求（默认：20）
ANALYSIS_MIN_DAYS=20

# ========================================
# 数据库配置（可选）
# ========================================

# PostgreSQL 连接
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stock_analyzer

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# ========================================
# API 配置（可选）
# ========================================

# FastAPI 配置
APP_SECRET_KEY=change-me-in-production
APP_ENV=development

# ========================================
# AI 配置（可选）
# ========================================

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229
