# Application
APP_NAME=stock-analyzer
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-here-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stock_analyzer
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Tushare
TUSHARE_TOKEN=your-tushare-token-here
TUSHARE_TIMEOUT=10
TUSHARE_MAX_RETRIES=3

# AKShare
AKSHARE_TIMEOUT=15
AKSHARE_MAX_RETRIES=3

# Cache
CACHE_TTL_DAILY=1800
CACHE_TTL_REALTIME=300
CACHE_TTL_FINANCIAL=86400

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=300

# Rate Limiting
RATE_LIMIT_FREE=10/minute
RATE_LIMIT_PRO=60/minute
RATE_LIMIT_ENTERPRISE=300/minute

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
