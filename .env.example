# Stock Analyzer 配置模板
# 复制此文件为 .env 并填写实际值

# ========================================
# 应用配置
# ========================================

# 应用名称
APP_NAME=stock-analyzer

# 运行环境：development | staging | production
APP_ENV=development

# 安全密钥（生产环境必须修改！）
APP_SECRET_KEY=change-me-in-production-at-least-32-characters

# 调试模式（生产环境设为 false）
APP_DEBUG=true

# ========================================
# 数据源配置
# ========================================

# Tushare API Token（必需）
# 获取地址：https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here

# ========================================
# 数据库配置
# ========================================

# PostgreSQL 连接
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stock_analyzer

# 数据库连接池大小
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# ========================================
# API 配置
# ========================================

# API 超时时间（秒）
API_TIMEOUT=30

# API 最大重试次数
API_MAX_RETRIES=3

# 重试延迟（秒）
API_RETRY_DELAY=1.0

# ========================================
# AI 配置（可选）
# ========================================

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# ========================================
# 加密配置
# ========================================

# 加密密钥（用于 API Key 加密存储）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ========================================
# Docker 部署配置
# ========================================

# PostgreSQL 密码（Docker 部署）
POSTGRES_PASSWORD=your_secure_password_here

# 镜像版本
VERSION=1.1.0

# ========================================
# 分析配置
# ========================================

# 日K线数据抓取天数
ANALYSIS_DAYS=120

# 最少数据天数要求
ANALYSIS_MIN_DAYS=20

# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志格式：json | text
LOG_FORMAT=text
