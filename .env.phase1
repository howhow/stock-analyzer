# Stock Analyzer Phase 1 配置
# 基于原有.env，新增Phase 1必需配置

# ========================================
# 数据源配置（保持原有）
# ========================================
TUSHARE_TOKEN=your_tushare_token_here

# ========================================
# 分析配置（保持原有）
# ========================================
ANALYSIS_DAYS=120
ANALYSIS_MIN_DAYS=20

# ========================================
# 数据库配置（Phase 1新增）
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stock_analyzer
REDIS_URL=redis://localhost:6379/0

# ========================================
# API 配置（Phase 1新增）
# ========================================
APP_SECRET_KEY=phase1-development-secret-key-change-in-production
APP_ENV=development

# ========================================
# 加密配置（Phase 1新增）
# ========================================
# AES-256-GCM加密密钥，用于加密敏感数据（API Key等）
# 生成命令：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=phase1-replace-with-actual-key

# ========================================
# AI 配置（Phase 1新增）
# ========================================
# OpenAI协议兼容（硅基流动/腾讯混元/DeepSeek等）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Anthropic协议（Claude系列）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# ========================================
# 飞书推送配置（Phase 1.2预留）
# ========================================
FEISHU_WEBHOOK_URL=
FEISHU_PUSH_ENABLED=false
